    GERENCIA: 8,
    COMITE: 9,
    ADMIN: 0
  };

  return map[value] || 1;
}

function getRuta(solicitud) {
  return (
    solicitud?.ruta_aprobacion ||
    solicitud?.scoring?.ruta_aprobacion ||
    solicitud?.area_responsable ||
    solicitud?.route ||
