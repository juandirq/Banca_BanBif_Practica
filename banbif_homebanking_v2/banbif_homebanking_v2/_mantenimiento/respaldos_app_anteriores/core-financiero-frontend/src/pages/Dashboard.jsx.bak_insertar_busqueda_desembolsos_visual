function safeGetRecommendation(solicitud) {
  const status = normalize(solicitud?.status);
  const ruta = String(getRuta(solicitud) || "").toUpperCase();
  const riesgo = normalize(solicitud?.scoring?.riesgo);
  const score = Number(solicitud?.scoring?.score || 0);
  const rds = getRdsPercent(solicitud);
  const monto = Number(solicitud?.amount || 0);
  const limite = getRoleLimit(getRuta(solicitud));

  if (status.includes("aprobado")) return "APROBADO";
  if (status.includes("rechazado")) return "RECHAZADO";
  if (status.includes("comite") || ruta.includes("COMITE")) return "DERIVAR A COMITE";

  if (riesgo.includes("alto") || score < 50 || rds > 45) {
    return "RECHAZAR";
  }

  if (monto > limite || ruta.includes("RIESGOS")) {
    return "DERIVAR A COMITE";
  }

  if (score >= 60 && rds <= 30 && monto <= limite) {
    return "APROBAR";
  }

  return "DERIVAR A COMITE";
}

function safeCanDecide(solicitud, role) {
  const status = normalize(solicitud?.status);
  const rutaSolicitud = toRoleKey(getRuta(solicitud));
  const roleActual = toRoleKey(role);
  const monto = Number(solicitud?.amount || 0);
  const limite = getRoleLimit(roleActual);

  if (status.includes("aprobado")) return false;
  if (status.includes("rechazado")) return false;
  if (status.includes("comite")) return false;

  if (roleActual === "COMITE" || roleActual === "GERENCIA") {
    return true;
  }

  // ADMIN supervisa el Core, pero no participa como aprobador crediticio ordinario.
  if (roleActual === "ADMIN") {
    return false;
  }

  if (rutaSolicitud === roleActual && monto <= limite) {
    return true;
  }

  return false;
}
