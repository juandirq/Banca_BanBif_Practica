            v.plazo_meses,
            v.ingreso_mensual,
            v.cuota_estimada,
            v.rds,
            v.rds_porcentaje,
            v.score,
            v.riesgo,
            v.semaforo,
            v.ruta_aprobacion,
            v.nivel_requerido,
            v.estado_credito,
            v.estado_desembolso,
            v.comentario_analista,
            v.fecha_solicitud,
            v.fecha_evaluacion,
            v.evaluado_por,
            v.cargo_evaluador,
            v.autonomia_evaluador,
            v.anio,
