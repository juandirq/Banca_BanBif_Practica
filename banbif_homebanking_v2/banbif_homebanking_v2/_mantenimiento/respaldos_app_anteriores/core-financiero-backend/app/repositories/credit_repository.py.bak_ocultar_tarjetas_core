def _num(value, default=0):
    try:
        if value is None or value == "":
            return default
        return float(value)
    except Exception:
        return default


def _texto_valido(value, invalidos=None):
    invalidos = invalidos or ["", "SIN EVALUAR", "PENDIENTE", "GRIS", "NULL", "NONE"]
    text = str(value or "").strip()
    if not text:
        return None
    if text.upper() in invalidos:
        return None
    return text


def _calcular_cuota_core(row: dict) -> float:
    monto = _num(row.get("amount") or row.get("monto") or row.get("monto_solicitado"))
    plazo = int(_num(row.get("term_months") or row.get("plazo_meses") or row.get("months"), 12))

    if monto <= 0 or plazo <= 0:
        return 0

    producto = str(row.get("product") or row.get("producto") or "").lower()

    if "vehicular" in producto:
        tea = 0.3999
    elif "mype" in producto or "negocio" in producto or "empresa" in producto:
        tea = 0.55
    elif "estudio" in producto:
        tea = 0.45
    else:
        tea = 0.899

    tasa_mensual = (1 + tea) ** (1 / 12) - 1
    factor = (1 + tasa_mensual) ** plazo

    if factor == 1:
        cuota_base = monto / plazo
    else:
        cuota_base = monto * ((tasa_mensual * factor) / (factor - 1))

    seguro = monto * 0.0007
    return cuota_base + seguro


def _ruta_por_politica(score: float, riesgo: str, rds_percent: float, monto: float) -> tuple:
    riesgo_upper = str(riesgo or "").upper()

    if riesgo_upper == "ALTO" or score < 50 or rds_percent > 40:
        return "RIESGOS", 7

    if monto > 60000:
        return "COMITE", 9

    if rds_percent > 30 or score < 80:
        if monto <= 25000:
            return "ANALISTA_N3", 3
        return "COMITE", 9

    if monto <= 10000:
        return "ANALISTA_N1", 1

    if monto <= 25000:
        return "ANALISTA_N2", 2

    if monto <= 60000:
        return "ANALISTA_N3", 3

    return "COMITE", 9


def _build_scoring(row: dict) -> dict:
    monto = _num(row.get("amount") or row.get("monto") or row.get("monto_solicitado"))
    ingreso = _num(row.get("monthly_income") or row.get("ingreso_mensual") or row.get("income"))
    cuota = _num(row.get("cuota_estimada") or row.get("monthly_payment"))

    if cuota <= 0:
        cuota = _calcular_cuota_core(row)

    rds = _num(row.get("rds"))
    rds_porcentaje = _num(row.get("rds_porcentaje") or row.get("rds_percent"))

    if rds_porcentaje <= 0:
        if rds > 0:
            rds_porcentaje = rds * 100 if rds <= 1 else rds
        elif cuota > 0 and ingreso > 0:
            rds_porcentaje = (cuota / ingreso) * 100

    if rds <= 0 and rds_porcentaje > 0:
        rds = rds_porcentaje / 100

    score = _num(row.get("score") or row.get("scoring_score"))

    if score <= 0:
        score = 70

        if rds_porcentaje <= 25:
            score += 22
        elif rds_porcentaje <= 30:
            score += 18
        elif rds_porcentaje <= 40:
            score += 5
        else:
            score -= 30

        if monto > 0 and ingreso > 0:
            ratio_monto_ingreso = monto / ingreso

            if ratio_monto_ingreso <= 6:
                score += 8
            elif ratio_monto_ingreso > 12:
                score -= 12

        score = max(0, min(100, score))

    riesgo_db = _texto_valido(row.get("riesgo") or row.get("risk_level"))

    if riesgo_db:
        riesgo = riesgo_db.upper()
    else:
        if score >= 80 and rds_porcentaje <= 30:
            riesgo = "BAJO"
        elif score >= 60 and rds_porcentaje <= 40:
            riesgo = "MEDIO"
        else:
            riesgo = "ALTO"

    semaforo_db = _texto_valido(row.get("semaforo") or row.get("risk_semaphore"))

    if semaforo_db:
        semaforo = semaforo_db.upper()
    elif riesgo == "BAJO":
        semaforo = "VERDE"
    elif riesgo == "MEDIO":
        semaforo = "AMARILLO"
    else:
        semaforo = "ROJO"

    ruta_db = _texto_valido(row.get("ruta_aprobacion") or row.get("approval_route"))
    nivel_db = _num(row.get("nivel_requerido") or row.get("required_approval_level"))

    if ruta_db:
        ruta_aprobacion = ruta_db.upper()
        nivel_requerido = int(nivel_db or 1)
    else:
        ruta_aprobacion, nivel_requerido = _ruta_por_politica(score, riesgo, rds_porcentaje, monto)

    comentario = (
        row.get("comentario_analista")
        or row.get("analyst_comment")
        or "Clasificacion automatica del Core segun score, RDS, monto y politica referencial."
    )

    return {
        "score": round(score, 2),
        "riesgo": riesgo,
        "semaforo": semaforo,
        "rds": round(rds, 4),
        "rds_porcentaje": round(rds_porcentaje, 2),
        "rds_percent": round(rds_porcentaje, 2),
        "ruta_aprobacion": ruta_aprobacion,
        "nivel_requerido": nivel_requerido,
        "cuota_estimada": round(cuota, 2),
        "comentario": comentario,
    }

def _normalize_credit_row(row) -> dict:
    item = normalize_row(row)

    # Compatibilidad con frontend anterior
    item["id"] = item.get("solicitud_id")
    item["user_id"] = item.get("cliente_id")
    item["product"] = item.get("producto")
    item["purpose"] = item.get("purpose") or item.get("proposito")
    item["amount"] = item.get("monto_solicitado")
    item["months"] = item.get("plazo_meses")
    item["monthly_income"] = item.get("ingreso_mensual")
    item["status"] = item.get("estado_credito")
    item["analyst_comment"] = item.get("comentario_analista")
    item["created_at"] = item.get("fecha_solicitud")

    # Objeto de evaluaciÃƒÆ’Ã‚Â³n crediticia
    scoring = _build_scoring(item)
    item["scoring"] = scoring

    # Propagar clasificacion al nivel principal para que el frontend no muestre PENDIENTE/SIN EVALUAR.
    item["score"] = scoring.get("score")
    item["riesgo"] = scoring.get("riesgo")
    item["semaforo"] = scoring.get("semaforo")
    item["rds"] = scoring.get("rds")
    item["rds_porcentaje"] = scoring.get("rds_porcentaje")
    item["ruta_aprobacion"] = scoring.get("ruta_aprobacion")
    item["nivel_requerido"] = scoring.get("nivel_requerido")
    item["cuota_estimada"] = scoring.get("cuota_estimada")

    return item


