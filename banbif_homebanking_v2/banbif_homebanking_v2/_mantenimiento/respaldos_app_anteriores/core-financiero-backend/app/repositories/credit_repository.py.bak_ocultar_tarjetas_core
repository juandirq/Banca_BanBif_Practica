def disburse_credit_application(solicitud_id: str, disbursed_by: int | None = None):
    with get_connection() as conn:
        credit = conn.execute(
            """
            SELECT *
            FROM creditapplication
            WHERE id = %s
            FOR UPDATE
            """,
            (solicitud_id,)
        ).fetchone()

        if not credit:
            return None

        credit_data = normalize_row(credit)

        if credit_data.get("status") != "Aprobado":
            raise ValueError("Solo se pueden desembolsar solicitudes aprobadas.")

        if credit_data.get("disbursement_status") == "Desembolsado":
            raise ValueError("La solicitud ya fue desembolsada.")

        account = conn.execute(
            """
            SELECT *
            FROM account
            WHERE user_id = %s
              AND status = 'Activa'
              AND currency = 'PEN'
            ORDER BY id ASC
            LIMIT 1
            FOR UPDATE
            """,
            (credit_data["user_id"],)
        ).fetchone()

        if not account:
            raise ValueError("El cliente no tiene una cuenta activa en PEN para desembolso.")

        account_data = normalize_row(account)
        amount = float(credit_data.get("amount") or 0)
        months = int(credit_data.get("months") or 1)
        estimated_installment = float(credit_data.get("estimated_installment") or 0)

        if amount <= 0:
            raise ValueError("El monto del credito no es valido.")

        conn.execute(
            """
            UPDATE account
            SET balance = balance + %s
            WHERE id = %s
            """,
            (amount, account_data["id"])
        )

        movement = conn.execute(
            """
            INSERT INTO movement
            (account_id, description, operation_type, amount, created_at)
            VALUES
            (%s, %s, %s, %s, now())
            RETURNING id
            """,
            (
                account_data["id"],
                f"Desembolso de credito #{solicitud_id} - {credit_data.get('product')}",
                "DESEMBOLSO_CREDITO",
                amount
            )
        ).fetchone()

        movement_data = normalize_row(movement)

        disbursement = conn.execute(
            """
            INSERT INTO credit_disbursement
            (credit_application_id, account_id, movement_id, amount, status, disbursed_by, created_at)
            VALUES
            (%s, %s, %s, %s, %s, %s, now())
            RETURNING id
            """,
            (
                credit_data["id"],
                account_data["id"],
                movement_data["id"],
                amount,
                "Desembolsado",
                disbursed_by
            )
        ).fetchone()

        existing_schedule = conn.execute(
            """
            SELECT COUNT(*) AS total
            FROM loan_schedule
            WHERE credit_application_id = %s
            """,
            (credit_data["id"],)
        ).fetchone()

        existing_schedule_data = normalize_row(existing_schedule)

        if int(existing_schedule_data.get("total") or 0) == 0:
            principal = round(amount / months, 2)

            if estimated_installment <= 0:
                estimated_installment = principal

            interest = round(max(estimated_installment - principal, 0), 2)

            for n in range(1, months + 1):
                due_date = conn.execute(
                    """
                    SELECT (CURRENT_DATE + (%s || ' months')::interval)::date AS due_date
                    """,
                    (n,)
                ).fetchone()

                due_date_data = normalize_row(due_date)

                conn.execute(
                    """
                    INSERT INTO loan_schedule
                    (credit_application_id, installment_number, due_date, principal_amount,
                     interest_amount, total_amount, paid_amount, status, days_past_due, created_at)
                    VALUES
                    (%s, %s, %s, %s, %s, %s, %s, %s, %s, now())
                    """,
                    (
                        credit_data["id"],
                        n,
                        due_date_data["due_date"],
                        principal,
                        interest,
                        round(principal + interest, 2),
                        0,
                        "Pendiente",
                        0
                    )
                )

        conn.execute(
            """
            UPDATE creditapplication
            SET disbursement_status = 'Desembolsado'
            WHERE id = %s
            """,
            (credit_data["id"],)
        )

        updated_account = conn.execute(
            """
            SELECT *
            FROM account
            WHERE id = %s
            """,
            (account_data["id"],)
        ).fetchone()

        conn.commit()

    return {
        "credit": get_credit_application(solicitud_id),
        "account": normalize_row(updated_account),
        "movement_id": movement_data["id"],
        "disbursement_id": normalize_row(disbursement)["id"],
        "amount": amount
    }


