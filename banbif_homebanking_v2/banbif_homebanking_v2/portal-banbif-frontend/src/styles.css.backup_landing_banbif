/* Mejoras bancarias: Cuenta Digital, Token y Estado de cuenta */
.account-benefits {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.account-benefits span {
  background: #eaf1ff;
  color: #0047ab;
  border-radius: 999px;
  padding: 8px 10px;
  font-size: 13px;
  font-weight: 800;
}

.statement-filters {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px;
  margin: 16px 0;
}

@media (max-width: 620px) {
  .statement-filters {
    grid-template-columns: 1fr;
  }
}

/* Toast global: abajo a la derecha, sin tapar formularios */
.toast {
  position: fixed !important;
  top: auto !important;
  left: auto !important;
  right: 26px !important;
  bottom: 26px !important;
  z-index: 9999 !important;
  width: auto !important;
  min-width: 280px !important;
  max-width: 360px !important;
  pointer-events: none !important;
}

@media (max-width: 620px) {
  .toast {
    left: 18px !important;
    right: 18px !important;
    bottom: 18px !important;
    max-width: none !important;
  }
}

/* Campo de contrasena con boton mostrar/ocultar */
.password-field {
  position: relative;
  width: 100%;
}

.password-field input {
  padding-right: 48px !important;
}

.password-toggle {
  position: absolute;
  top: 50%;
  right: 12px;
  transform: translateY(-50%);
  border: 0;
  background: transparent;
  color: #64748b;
  width: 34px;
  height: 34px;
  border-radius: 10px;
  display: grid;
  place-items: center;
  cursor: pointer;
  transition: 0.18s ease;
}

.password-toggle:hover {
  background: #eef3fb;
  color: #0047ab;
}


/* Simulador de credito - alertas de elegibilidad */
.warning-note {
  color: #991b1b !important;
  background: #fff1f2 !important;
  border: 1px solid #fecdd3 !important;
  border-radius: 14px !important;
  padding: 12px 14px !important;
  font-weight: 800 !important;
}

button.primary:disabled {
  opacity: 0.55 !important;
  cursor: not-allowed !important;
}
