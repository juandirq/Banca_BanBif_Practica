:root {
  font-family: Inter, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  color: #0f172a;
  background: #f3f6fb;
}

* {
  box-sizing: border-box;
}

body {
  margin: 0;
  background: #f3f6fb;
}

button,
input,
select {
  font: inherit;
}

button {
  cursor: pointer;
}

.auth-page {
  min-height: 100vh;
  display: grid;
  grid-template-columns: 1.1fr 0.9fr;
  background: #f3f6fb;
}

.auth-hero {
  color: white;
  padding: 56px;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  background:
    radial-gradient(circle at top left, rgba(59, 130, 246, 0.48), transparent 32%),
    radial-gradient(circle at bottom right, rgba(14, 165, 233, 0.20), transparent 28%),
    linear-gradient(135deg, #061329, #0b2858 62%, #0047ab);
  overflow: hidden;
  position: relative;
}

.auth-hero::after {
  content: "";
  position: absolute;
  width: 340px;
  height: 340px;
  border-radius: 999px;
  right: -90px;
  bottom: -120px;
  background: rgba(255, 255, 255, 0.08);
  filter: blur(2px);
}

.brand,
.side-brand,
.auth-title {
  display: flex;
  align-items: center;
  gap: 14px;
  position: relative;
  z-index: 1;
}

.brand-icon,
.side-brand svg {
  background: #0047ab;
  color: white;
  border-radius: 18px;
  padding: 10px;
  width: 56px;
  height: 56px;
}

.brand h1,
.topbar h1,
.hero-content h2,
.auth-title h2,
.page-title h2 {
  margin: 0;
}

.brand p,
.topbar p,
.panel p,
.hero-content p,
.auth-title p,
.page-title p {
  margin: 6px 0 0;
  opacity: 0.72;
}

.hero-content {
  max-width: 650px;
  animation: fadeUp 0.7s ease both;
  position: relative;
  z-index: 1;
}

.badge,
.section-label {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  width: fit-content;
  border-radius: 999px;
  padding: 8px 12px;
  background: rgba(255, 255, 255, 0.13);
  border: 1px solid rgba(255, 255, 255, 0.18);
  font-size: 13px;
  margin-bottom: 18px;
}

.hero-content h2 {
  font-size: clamp(34px, 5vw, 58px);
  line-height: 1.04;
  letter-spacing: -1.5px;
}

.hero-content p {
  max-width: 560px;
  font-size: 17px;
  line-height: 1.7;
}

.hero-stats {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14px;
  margin-top: 28px;
}

.hero-stats div {
  background: rgba(255, 255, 255, 0.11);
  border: 1px solid rgba(255, 255, 255, 0.16);
  border-radius: 20px;
  padding: 16px;
  backdrop-filter: blur(10px);
}

.hero-stats strong {
  display: block;
  font-size: 24px;
}

.hero-stats span {
  opacity: 0.75;
  font-size: 13px;
}

.auth-panel {
  display: grid;
  place-items: center;
  padding: 42px;
}

.auth-card {
  width: min(440px, 100%);
  background: white;
  border-radius: 30px;
  padding: 30px;
  box-shadow: 0 28px 70px rgba(15, 23, 42, 0.18);
  animation: fadeUp 0.55s ease both;
}

.auth-title {
  align-items: flex-start;
  margin-bottom: 24px;
}

.auth-title svg {
  color: #0047ab;
}

.form,
.module-form {
  display: grid;
  gap: 12px;
}

label {
  color: #475569;
  font-size: 14px;
  font-weight: 650;
}

input,
select {
  width: 100%;
  border: 1px solid #d7dfeb;
  background: white;
  border-radius: 14px;
  padding: 13px 14px;
  outline: none;
  transition: 0.18s ease;
}

input:focus,
select:focus {
  border-color: #0047ab;
  box-shadow: 0 0 0 4px rgba(0, 71, 171, 0.1);
}

.check-line {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  background: #f8fbff;
  border: 1px solid #e5eaf3;
  border-radius: 16px;
  padding: 12px;
  line-height: 1.35;
}

.check-line input {
  width: auto;
  margin-top: 2px;
}

.primary,
.ghost,
.logout,
.notification,
.mini-link,
.card-action {
  border: 0;
  border-radius: 14px;
  padding: 13px 16px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  transition: 0.18s ease;
}

.primary {
  background: #0047ab;
  color: white;
  font-weight: 800;
  box-shadow: 0 12px 25px rgba(0, 71, 171, 0.22);
}

.primary:hover:not(:disabled) {
  transform: translateY(-1px);
  background: #003987;
}

.primary:disabled {
  opacity: 0.55;
  cursor: not-allowed;
  box-shadow: none;
}

.primary.small {
  padding: 10px 14px;
}

.ghost,
.notification,
.mini-link {
  background: #eef3fb;
  color: #0047ab;
  font-weight: 750;
}

.ghost:hover,
.notification:hover,
.mini-link:hover {
  background: #dbeafe;
}

.notification {
  position: relative;
  width: 48px;
}

.notification span {
  position: absolute;
  top: -6px;
  right: -5px;
  background: #ef4444;
  color: white;
  border-radius: 999px;
  font-size: 11px;
  padding: 3px 6px;
}

.auth-switch {
  color: #64748b;
  text-align: center;
  margin: 6px 0 0;
}

.auth-switch button {
  border: 0;
  background: transparent;
  color: #0047ab;
  font-weight: 800;
}

.message,
.toast {
  border-radius: 16px;
  padding: 12px 14px;
}

.message {
  margin-top: 16px;
}

.toast {
  position: sticky;
  top: 14px;
  z-index: 20;
  display: flex;
  align-items: center;
  gap: 10px;
  width: fit-content;
  max-width: 100%;
  animation: fadeUp 0.35s ease both;
  box-shadow: 0 18px 38px rgba(15, 23, 42, 0.10);
}

.toast.success,
.message {
  background: #ecfdf3;
  color: #166534;
  border: 1px solid #bbf7d0;
}

.toast.error {
  background: #fff1f2;
  color: #be123c;
  border: 1px solid #fecdd3;
}

.toast.info {
  background: #eff6ff;
  color: #1d4ed8;
  border: 1px solid #bfdbfe;
}

.app-shell {
  display: grid;
  grid-template-columns: 280px 1fr;
  min-height: 100vh;
}

.sidebar {
  background: #07152d;
  color: white;
  padding: 26px;
  position: sticky;
  top: 0;
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.side-brand {
  margin-bottom: 34px;
}

.side-brand span {
  display: block;
  color: #9fb3d9;
  font-size: 13px;
}

.nav-menu {
  display: grid;
  gap: 10px;
}

.nav-menu button {
  border: 0;
  width: 100%;
  color: #dbeafe;
  background: transparent;
  text-align: left;
  padding: 12px 14px;
  border-radius: 14px;
  display: flex;
  align-items: center;
  gap: 10px;
  transition: 0.18s ease;
}

.nav-menu button:hover,
.nav-menu button.active {
  background: rgba(255, 255, 255, 0.12);
  color: white;
  transform: translateX(3px);
}

.side-note {
  margin-top: 28px;
  border: 1px solid rgba(255, 255, 255, 0.12);
  border-radius: 18px;
  padding: 14px;
  background: rgba(255, 255, 255, 0.06);
}

.side-note span {
  display: block;
  color: #9fb3d9;
  font-size: 12px;
}

.side-note strong {
  display: block;
  margin-top: 4px;
  font-size: 14px;
}

.logout {
  margin-top: auto;
  background: rgba(255, 255, 255, 0.1);
  color: white;
}

.logout:hover {
  background: rgba(255, 255, 255, 0.18);
}

.content {
  padding: 30px;
  display: grid;
  gap: 22px;
}

.topbar {
  background: white;
  border-radius: 24px;
  padding: 22px;
  box-shadow: 0 16px 45px rgba(15, 23, 42, 0.08);
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.top-actions {
  display: flex;
  gap: 10px;
}

.page-stack {
  display: grid;
  gap: 20px;
  animation: fadeUp 0.35s ease both;
}

.summary-hero,
.page-title,
.metric,
.panel {
  background: white;
  border-radius: 24px;
  padding: 22px;
  box-shadow: 0 16px 45px rgba(15, 23, 42, 0.08);
  transition: 0.2s ease;
}

.summary-hero {
  background:
    radial-gradient(circle at right, rgba(37, 99, 235, 0.18), transparent 32%),
    white;
  border-radius: 28px;
  padding: 26px;
  display: grid;
  grid-template-columns: 1.5fr 0.8fr;
  gap: 22px;
  align-items: center;
}

.section-label {
  background: #eaf1ff;
  color: #0047ab;
  border: 0;
  margin-bottom: 10px;
  font-weight: 800;
}

.summary-hero h2,
.page-title h2 {
  font-size: 34px;
  letter-spacing: -0.7px;
}

.alert-strip {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-top: 18px;
}

.alert-strip span {
  background: #fff7ed;
  color: #c2410c;
  border: 1px solid #fed7aa;
  padding: 8px 10px;
  border-radius: 999px;
  font-size: 13px;
  font-weight: 750;
}

.bank-card,
.account-card {
  border-radius: 24px;
  padding: 22px;
  background: linear-gradient(135deg, #0047ab, #082f69);
  color: white;
  box-shadow: 0 22px 45px rgba(0, 71, 171, 0.22);
  transition: 0.2s ease;
}

.bank-card:hover,
.account-card:hover,
.metric:hover,
.panel:hover {
  transform: translateY(-2px);
}

.bank-card span,
.account-card span,
.account-card p {
  opacity: 0.82;
}

.bank-card strong,
.account-card strong {
  display: block;
  margin: 8px 0;
  letter-spacing: 2px;
  font-size: 23px;
}

.bank-card h3,
.account-card h3 {
  margin: 16px 0 0;
  font-size: 30px;
}

.card-action {
  margin-top: 16px;
  background: rgba(255, 255, 255, 0.14);
  color: white;
  width: 100%;
}

.card-action:hover {
  background: rgba(255, 255, 255, 0.22);
}

.metric-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 18px;
}

.metric {
  display: grid;
  gap: 8px;
}

.metric svg {
  color: #0047ab;
}

.metric span {
  color: #64748b;
  font-weight: 750;
}

.metric strong {
  font-size: 28px;
}

.metric small {
  color: #64748b;
}

.two-columns,
.profile-grid {
  display: grid;
  grid-template-columns: 1.1fr 0.9fr;
  gap: 20px;
}

.panel-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
  margin-bottom: 18px;
}

.quick-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px;
}

.quick-grid button {
  border: 1px solid #dbeafe;
  background: #f8fbff;
  color: #0f172a;
  border-radius: 18px;
  padding: 16px;
  display: grid;
  gap: 8px;
  justify-items: start;
  font-weight: 800;
  transition: 0.18s ease;
}

.quick-grid button:hover {
  border-color: #0047ab;
  transform: translateY(-2px);
}

.quick-grid svg {
  color: #0047ab;
}

.notice {
  margin-top: 16px;
  background: #f0fdf4;
  border: 1px solid #bbf7d0;
  color: #166534;
  padding: 14px;
  border-radius: 18px;
  display: flex;
  align-items: flex-start;
  gap: 10px;
}

.account-list {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
  gap: 14px;
}

.simple-account {
  border: 1px solid #e5eaf3;
  border-radius: 18px;
  padding: 18px;
  display: grid;
  gap: 8px;
  background: #fbfdff;
}

.simple-account span {
  color: #64748b;
}

.simple-account b {
  color: #0047ab;
}

.module-form {
  grid-template-columns: repeat(auto-fit, minmax(190px, 1fr));
  align-items: end;
}

.table,
.info-list {
  display: grid;
  gap: 10px;
}

.row {
  display: flex;
  justify-content: space-between;
  gap: 18px;
  align-items: center;
  border: 1px solid #e5eaf3;
  border-radius: 16px;
  padding: 14px;
  background: #fff;
  transition: 0.16s ease;
}

.row:hover {
  background: #f8fbff;
  border-color: #cbdaf2;
}

.row span,
.info-list span,
.preview-box span,
.risk-card span {
  display: block;
  color: #64748b;
  font-size: 14px;
  margin-top: 4px;
}

.right-info {
  text-align: right;
}

.right-info small {
  display: block;
  color: #0047ab;
  margin-top: 4px;
  font-weight: 750;
}

.preview-box {
  display: grid;
  gap: 12px;
}

.preview-box div {
  border: 1px solid #e5eaf3;
  border-radius: 16px;
  padding: 14px;
  background: #fbfdff;
}

.preview-box strong {
  display: block;
  margin-top: 6px;
}

.risk-card {
  border-radius: 22px;
  padding: 20px;
  color: white;
  background: linear-gradient(135deg, #0047ab, #0f766e);
  margin-bottom: 14px;
}

.risk-card strong {
  display: block;
  font-size: 34px;
  margin: 8px 0 2px;
}

.risk-card p {
  color: white;
  opacity: 0.82;
}

.help-note {
  margin-top: 14px;
  background: #eff6ff;
  color: #1d4ed8;
  border: 1px solid #bfdbfe;
  padding: 12px;
  border-radius: 16px;
}

.danger-note {
  margin: 0;
  background: #fff1f2;
  color: #be123c;
  border: 1px solid #fecdd3;
  padding: 12px;
  border-radius: 16px;
  font-weight: 750;
}

.positive {
  color: #15803d;
}

.negative {
  color: #b91c1c;
}

.empty {
  color: #64748b;
}

.profile-card {
  text-align: center;
}

.avatar {
  width: 84px;
  height: 84px;
  border-radius: 28px;
  display: grid;
  place-items: center;
  margin: 0 auto 14px;
  background: #0047ab;
  color: white;
  font-size: 34px;
  font-weight: 900;
}

.info-list div {
  border: 1px solid #e5eaf3;
  border-radius: 16px;
  padding: 14px;
  background: #fbfdff;
}

.info-list strong {
  display: block;
  margin-top: 5px;
}

@keyframes fadeUp {
  from {
    opacity: 0;
    transform: translateY(12px);
  }

  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@media (max-width: 1040px) {
  .auth-page,
  .app-shell,
  .summary-hero,
  .two-columns,
  .profile-grid {
    grid-template-columns: 1fr;
  }

  .sidebar {
    position: static;
    height: auto;
  }

  .metric-grid {
    grid-template-columns: 1fr 1fr;
  }
}

@media (max-width: 620px) {
  .auth-hero,
  .auth-panel,
  .content {
    padding: 22px;
  }

  .metric-grid,
  .quick-grid,
  .hero-stats {
    grid-template-columns: 1fr;
  }

  .topbar,
  .panel-head {
    flex-direction: column;
    align-items: flex-start;
  }

  .row {
    flex-direction: column;
    align-items: flex-start;
  }

  .right-info {
    text-align: left;
  }
}
/* Ajustes finales de experiencia bancaria */
.toast {
  position: fixed;
  top: 24px;
  right: 24px;
  z-index: 50;
  min-width: 280px;
  max-width: 420px;
  pointer-events: none;
}

.notification-wrap {
  position: relative;
}

.notification-panel {
  position: absolute;
  top: 58px;
  right: 0;
  width: 310px;
  background: white;
  border: 1px solid #e5eaf3;
  border-radius: 20px;
  padding: 16px;
  box-shadow: 0 24px 55px rgba(15, 23, 42, 0.18);
  z-index: 40;
  animation: fadeUp 0.22s ease both;
}

.notification-panel h3 {
  margin: 0 0 10px;
}

.notification-panel p {
  margin: 0;
  color: #64748b;
}

.notification-item {
  display: flex;
  gap: 10px;
  align-items: flex-start;
  padding: 10px;
  background: #f8fbff;
  border: 1px solid #e5eaf3;
  border-radius: 14px;
  margin-top: 8px;
  color: #0f172a;
}

.notification-item svg {
  color: #16a34a;
  flex-shrink: 0;
}

.hero-illustration {
  position: relative;
  height: 130px;
  margin-top: 24px;
}

.phone-card {
  width: 210px;
  background: rgba(255, 255, 255, 0.13);
  border: 1px solid rgba(255, 255, 255, 0.18);
  border-radius: 24px;
  padding: 18px;
  backdrop-filter: blur(12px);
  display: grid;
  gap: 8px;
}

.phone-card svg {
  color: #bfdbfe;
}

.phone-card span {
  opacity: 0.78;
  font-size: 13px;
}

.phone-card strong {
  font-size: 26px;
}

.mini-card {
  position: absolute;
  left: 170px;
  top: 44px;
  background: white;
  color: #0f172a;
  border-radius: 18px;
  padding: 12px 14px;
  box-shadow: 0 18px 45px rgba(0, 0, 0, 0.18);
  display: flex;
  align-items: center;
  gap: 8px;
}

.floating {
  animation: floatCard 2.8s ease-in-out infinite;
}

@keyframes floatCard {
  0%, 100% {
    transform: translateY(0);
  }

  50% {
    transform: translateY(-7px);
  }
}

@media (max-width: 620px) {
  .toast {
    left: 18px;
    right: 18px;
    top: 18px;
    min-width: auto;
  }

  .notification-panel {
    right: auto;
    left: 0;
    width: min(310px, 86vw);
  }

  .mini-card {
    left: 120px;
  }
}

/* Correccion login: menos ancho y sin tarjeta flotante */
.auth-page {
  grid-template-columns: minmax(420px, 0.9fr) minmax(430px, 1.1fr);
}

.auth-hero {
  padding: 42px 54px;
}

.hero-content h2 {
  font-size: clamp(32px, 4vw, 48px);
}

.hero-content {
  max-width: 600px;
}

.auth-card {
  width: min(430px, 100%);
}

.hero-illustration,
.phone-card,
.mini-card {
  display: none !important;
}

/* Ajuste final: mensaje flotante abajo a la derecha */
.toast {
  top: auto !important;
  right: 28px !important;
  bottom: 28px !important;
  left: auto !important;
}

@media (max-width: 620px) {
  .toast {
    left: 18px !important;
    right: 18px !important;
    bottom: 18px !important;
    top: auto !important;
  }
}

